<?php

/**
 * @file
 * Contains data_stream_notification.module.
 */

declare(strict_types=1);

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\data_stream_notification\Hook\DataStreamNotificationHooks;

/**
 * Implements hook_mail().
 */
#[LegacyHook]
function data_stream_notification_mail($key, &$message, $params)
{
    return \Drupal::service(DataStreamNotificationHooks::class)->mail($key, $message, $params);
}
