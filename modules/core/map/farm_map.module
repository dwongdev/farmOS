<?php

/**
 * @file
 * The farm_map module.
 */

declare(strict_types=1);

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\farm_map\Hook\FarmMapHooks;

/**
 * Implements hook_theme().
 */
#[LegacyHook]
function farm_map_theme($existing, $type, $theme, $path) {
  return \Drupal::service(FarmMapHooks::class)->theme($existing, $type, $theme, $path);
}
