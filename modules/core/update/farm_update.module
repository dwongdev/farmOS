<?php

/**
 * @file
 * Hooks and customizations for the farm_update module.
 */

declare(strict_types=1);

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\farm_update\Hook\FarmUpdateHooks;

/**
 * Implements hook_rebuild().
 */
#[LegacyHook]
function farm_update_rebuild() {
  \Drupal::service(FarmUpdateHooks::class)->rebuild();
}

/**
 * Implements hook_farm_update_exclude_config().
 */
#[LegacyHook]
function farm_update_farm_update_exclude_config() {

  return \Drupal::service(FarmUpdateHooks::class)->farmUpdateExcludeConfig();
}
