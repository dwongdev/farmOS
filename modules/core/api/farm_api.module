<?php

/**
 * @file
 * Contains farm_api.module.
 */

declare(strict_types=1);

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\farm_api\Hook\FarmApiHooks;

/**
 * Implements hook_farm_api_allow_resource_types().
 */
#[LegacyHook]
function farm_api_farm_api_allow_resource_types() {

  return \Drupal::service(FarmApiHooks::class)->farmApiAllowResourceTypes();
}
