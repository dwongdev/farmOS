<?php

/**
 * @file
 * Contains farm_api_oauth.module.
 */

declare(strict_types=1);

use Drupal\Core\Entity\EntityTypeInterface;
use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\farm_api_oauth\Hook\FarmApiOauthHooks;

/**
 * Implements hook_entity_base_field_info().
 */
#[LegacyHook]
function farm_api_oauth_entity_base_field_info(EntityTypeInterface $entity_type) {
  return \Drupal::service(FarmApiOauthHooks::class)->entityBaseFieldInfo($entity_type);
}

/**
 * Implements hook_consumers_list_alter().
 *
 * Display the client_id in the list of consumers.
 */
#[LegacyHook]
function farm_api_oauth_consumers_list_alter(&$data, $context) {
  \Drupal::service(FarmApiOauthHooks::class)->consumersListAlter($data, $context);
}
