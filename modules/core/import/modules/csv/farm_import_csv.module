<?php

/**
 * @file
 * Hooks provided by farm_import_csv.
 */

declare(strict_types=1);

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\farm_import_csv\Hook\FarmImportCsvHooks;
use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_file_download().
 */
#[LegacyHook]
function farm_import_csv_file_download($uri)
{
    return \Drupal::service(FarmImportCsvHooks::class)->fileDownload($uri);
}

/**
 * Implements hook_entity_delete().
 */
#[LegacyHook]
function farm_import_csv_entity_delete(EntityInterface $entity) {

  \Drupal::service(FarmImportCsvHooks::class)->entityDelete($entity);
}
