<?php

/**
 * @file
 * Contains farm_owner.module.
 */

declare(strict_types=1);

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\farm_owner\Hook\FarmOwnerHooks;
use Drupal\Core\Entity\EntityTypeInterface;

/**
 * Implements hook_entity_base_field_info().
 */
#[LegacyHook]
function farm_owner_entity_base_field_info(EntityTypeInterface $entity_type)
{
    return \Drupal::service(FarmOwnerHooks::class)->entityBaseFieldInfo($entity_type);
}
