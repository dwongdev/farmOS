<?php

/**
 * @file
 * Contains farm_image.module.
 */

declare(strict_types=1);

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\farm_image\Hook\FarmImageHooks;

/**
 * Implements hook_farm_update_exclude_config().
 */
#[LegacyHook]
function farm_image_farm_update_exclude_config() {

  return \Drupal::service(FarmImageHooks::class)->farmUpdateExcludeConfig();
}
