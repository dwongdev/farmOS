<?php

/**
 * @file
 * The farm_timeline module.
 */

declare(strict_types=1);

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\farm_timeline\Hook\FarmTimelineHooks;

/**
 * Implements hook_theme().
 */
#[LegacyHook]
function farm_timeline_theme($existing, $type, $theme, $path) {
  return \Drupal::service(FarmTimelineHooks::class)->theme($existing, $type, $theme, $path);
}
