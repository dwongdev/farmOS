<?php

/**
 * @file
 * Hooks implemented by the Farm Worker module.
 */

declare(strict_types=1);

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\farm_worker\Hook\FarmWorkerHooks;

/**
 * Implements hook_oauth2_scope_info_alter().
 */
#[LegacyHook]
function farm_worker_oauth2_scope_info_alter(array &$scopes) {

  \Drupal::service(FarmWorkerHooks::class)->oauth2ScopeInfoAlter($scopes);
}
