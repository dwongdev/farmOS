<?php

/**
 * @file
 * Hooks implemented by the Farm Viewer module.
 */

declare(strict_types=1);

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\farm_viewer\Hook\FarmViewerHooks;

/**
 * Implements hook_oauth2_scope_info_alter().
 */
#[LegacyHook]
function farm_viewer_oauth2_scope_info_alter(array &$scopes) {

  \Drupal::service(FarmViewerHooks::class)->oauth2ScopeInfoAlter($scopes);
}
